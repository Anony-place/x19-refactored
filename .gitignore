```gitignore
# Compiled and binary files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Test coverage
.coverage
coverage/
htmlcov/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
target/
*.out
*.exe
*.dll
*.so
*.a
*.class

# Python specific
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Cache directories
.mypy_cache/
.pytest_cache/
.hypothesis/
```